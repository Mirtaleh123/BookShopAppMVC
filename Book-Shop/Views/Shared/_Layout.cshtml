<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ali_və_Nino_Kitab_Mağazası</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ali_və_Nino_Kitab_Mağazası.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white shadow-sm">
            <div class="container-fluid">

                <!-- Logo -->
                <a class="navbar-brand" asp-controller="Book" asp-action="Index">
                    <img src="https://static.insales-cdn.com/r/XA2GG-fJxr0/rs:fill-down:100:100:1/q:100/plain/files/1/2841/119417625/original/Logo_3__1_.png@png"
                         width="80"
                         height="80"
                         alt="Logo" />
                </a>

                <!-- Mobile Button -->
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navbar Content -->
                <div class="collapse navbar-collapse" id="navbarContent">

                    <!-- Left Menu -->
                    <ul class="navbar-nav me-4">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold"
                               asp-controller="Home"
                               asp-action="Privacy">
                                Privacy
                            </a>
                        </li>
                    </ul>

                    <!-- Search -->
                    <form method="get"
                          asp-controller="Book"
                          asp-action="Index"
                          class="d-flex me-auto">

                        <input class="form-control me-2"
                               type="search"
                               name="search"
                               placeholder="Kitab axtar..." />

                        <button class="btn btn-warning text-white">
                            Axtar
                        </button>
                    </form>

                    <!-- Right Side User -->
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="d-flex align-items-center gap-3">

                            <span class="fw-semibold text-dark">
                                Salam, @User.Identity.Name 👋
                            </span>

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm">
                                    Çıxış et
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="Login"
                           class="btn btn-warning text-white">
                            Giriş et
                        </a>
                    }

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Ali_və_Nino_Kitab_Mağazası - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
